{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "참괜찮은 사무실 위젯",
  "version": "0.1.1",
  "identifier": "com.chamgwenchana.officewidget",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "참괜찮은 사무실 위젯",
        "width": 360,
        "height": 560,
        "minWidth": 260,
        "minHeight": 300,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}